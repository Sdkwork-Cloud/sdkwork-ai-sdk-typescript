{
  "name": "@sdkwork/ai-sdk",
  "version": "1.0.0",
  "description": "SDKwork AI SDK - AI API Gateway TypeScript SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./http": {
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs",
      "types": "./dist/http/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs",
      "types": "./dist/auth/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs",
      "types": "./dist/types/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "require": "./dist/api/index.cjs",
      "types": "./dist/api/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "sdkwork",
    "ai",
    "sdk",
    "openai",
    "chatgpt",
    "llm"
  ],
  "author": "SDKwork",
  "license": "MIT",
  "dependencies": {
    "@sdkwork/sdk-common": "file:../../../sdk/sdkwork-sdk-common-typescript"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-dts": "^3.7.0",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sdkwork/ai-sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/sdkwork/ai-sdk-typescript/issues"
  },
  "homepage": "https://github.com/sdkwork/ai-sdk-typescript#readme"
}
